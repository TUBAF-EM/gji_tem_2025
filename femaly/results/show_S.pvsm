          <Entry value="8" text="Same as Input"/>
          <Entry value="0" text="vtkPolyData"/>
          <Entry value="2" text="vtkStructuredGrid"/>
          <Entry value="3" text="vtkRectilinearGrid"/>
          <Entry value="4" text="vtkUnstructuredGrid"/>
          <Entry value="6" text="vtkImageData"/>
          <Entry value="10" text="vtkUniformGrid"/>
          <Entry value="13" text="vtkMultiblockDataSet"/>
          <Entry value="15" text="vtkHierarchicalBoxDataSet"/>
          <Entry value="32" text="vtkHyperTreeGrid"/>
          <Entry value="19" text="vtkTable"/>
          <Entry value="33" text="vtkMolecule"/>
          <Entry value="37" text="vtkPartitionedDataSet"/>
          <Entry value="38" text="vtkPartitionedDataSetCollection"/>
        </Domain>
      </Property>
      <Property name="PythonPath" id="16039.PythonPath" number_of_elements="1">
        <Element index="0" value=""/>
      </Property>
      <Property name="Script" id="16039.Script" number_of_elements="1">
        <Element index="0" value="import vtk&#xa;&#xa;pdi = self.GetInput()&#xa;pdo = self.GetOutput()&#xa;&#xa;# Copy points from input&#xa;npts = pdi.GetNumberOfPoints()&#xa;if npts &#x3c; 2:&#xa;    # Not enough points to make a line&#xa;    pdo.ShallowCopy(pdi)&#xa;else:&#xa;    points = vtk.vtkPoints()&#xa;    points.DeepCopy(pdi.GetPoints())&#xa;&#xa;    # Make a polyline&#xa;    lines = vtk.vtkCellArray()&#xa;    polyLine = vtk.vtkPolyLine()&#xa;    polyLine.GetPointIds().SetNumberOfIds(npts)&#xa;&#xa;    for i in range(npts):&#xa;        polyLine.GetPointIds().SetId(i, i)&#xa;&#xa;    lines.InsertNextCell(polyLine)&#xa;&#xa;    pdo.SetPoints(points)&#xa;    pdo.SetLines(lines)"/>
      </Property>
      <Property name="TimestepValues" id="16039.TimestepValues"/>
      <Property name="UpdateExtentScript" id="16039.UpdateExtentScript" number_of_elements="1">
        <Element index="0" value=""/>
      </Property>
    </Proxy>
